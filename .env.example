# Copy to .env and fill in. Never commit the real .env.
BOT_TOKEN=123456:your-telegram-bot-token
OPENAI_API_KEY=sk-...
# Needed only when AUDIO_SOURCE=elevenlabs (the key just needs text_to_speech).
ELEVENLABS_API_KEY=

# Audio source for patches:
#   elevenlabs = AI voice on freshly generated themed snippets (any text/language)
#   tatoeba    = real native-speaker recordings (limited, CC-BY pool)
AUDIO_SOURCE=elevenlabs
# eleven_multilingual_v2 = best quality (1 credit/char); eleven_flash_v2_5 = ~half cost.
ELEVENLABS_MODEL=eleven_multilingual_v2
# Optional: pin specific voice ids (comma-separated). Empty = random from a curated pool.
ELEVENLABS_VOICE_IDS=

# Numeric Telegram user id allowed to run /test_send (0 disables the command).
ADMIN_ID=969978048

# Daily delivery. The exact time is randomised each day (BeReal-style) inside
# the [START, END) hour window in this timezone.
TIMEZONE=Europe/Kyiv
SEND_WINDOW_START_HOUR=9
SEND_WINDOW_END_HOUR=21

# Default learning setup for new users (ISO 639-3 codes).
DEFAULT_LANGUAGE=ukr
NATIVE_LANGUAGE=rus

# Optional override for the vocabulary model.
OPENAI_MODEL=gpt-4o-mini

# Persist DB + audio on a volume in production (Railway: mount a volume at /data).
# DB_PATH=/data/bot.db
# MEDIA_DIR=/data/media

# Optional: auto-seed the pool on boot (comma-separated codes). Empty = disabled.
# SEED_ON_START=ukr
# SEED_COUNT=10

# Optional: on boot, keep at most N 'tatoeba' items per seeded language (delete the
# rest). 0 = keep all. Handy when switching to elevenlabs but keeping a few real clips.
# KEEP_TATOEBA=0

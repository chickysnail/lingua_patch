# Copy to .env and fill in. Never commit the real .env.
BOT_TOKEN=123456:your-telegram-bot-token
OPENAI_API_KEY=sk-...

# Numeric Telegram user id allowed to run /test_send (0 disables the command).
ADMIN_ID=969978048

# Daily delivery. The exact time is randomised each day (BeReal-style) inside
# the [START, END) hour window in this timezone.
TIMEZONE=Europe/Kyiv
SEND_WINDOW_START_HOUR=9
SEND_WINDOW_END_HOUR=21

# Default learning setup for new users (ISO 639-3 codes).
DEFAULT_LANGUAGE=ukr
NATIVE_LANGUAGE=rus

# Optional override for the vocabulary model.
OPENAI_MODEL=gpt-4o-mini
